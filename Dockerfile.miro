# Dockerfile.miro
# Builds the MiRo ROS bridge container.
#
# Build:  docker build -f Dockerfile.miro -t miro-bridge .
# Run:    docker run --rm --network host miro-bridge
#
# --network host lets the bridge reach localhost:5001 from the FastAPI app
# and lets ROS talk to the Gazebo simulator on the same machine.

FROM ros:noetic-ros-base

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-numpy \
    && rm -rf /var/lib/apt/lists/*

# Copy the MiRo MDK (pre-built catkin install + Python library)
COPY claude/mdk-230105 /mdk

# Copy the bridge script
COPY miro_bridge.py /app/miro_bridge.py

WORKDIR /app

ENV MIRO_ROBOT_NAME=sim01

CMD ["/bin/bash", "-c", "\
    source /opt/ros/noetic/setup.bash && \
    source /mdk/catkin_ws/install/setup.bash && \
    export PYTHONPATH=/mdk/share/python:$PYTHONPATH && \
    python3 /app/miro_bridge.py"]
